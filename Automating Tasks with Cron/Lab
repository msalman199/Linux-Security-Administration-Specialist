Let's create several cron jobs with different schedules.

# Create a system monitoring script
cat > ~/cron_scripts/system_monitor.sh << 'EOF'
#!/bin/bash
# System monitoring script
LOG_FILE="$HOME/cron_logs/system_monitor.log"
DATE=$(date '+%Y-%m-%d %H:%M:%S')

echo "=== System Monitor Report - $DATE ===" >> $LOG_FILE
echo "CPU Usage:" >> $LOG_FILE
top -bn1 | grep "Cpu(s)" >> $LOG_FILE
echo "Memory Usage:" >> $LOG_FILE
free -h >> $LOG_FILE
echo "Disk Usage:" >> $LOG_FILE
df -h / >> $LOG_FILE
echo "Load Average:" >> $LOG_FILE
uptime >> $LOG_FILE
echo "----------------------------------------" >> $LOG_FILE
echo "" >> $LOG_FILE
EOF

# Create a backup script
cat > ~/cron_scripts/backup_script.sh << 'EOF'
#!/bin/bash
# Simple backup script
BACKUP_DIR="$HOME/backups"
DATE=$(date '+%Y%m%d_%H%M%S')
LOG_FILE="$HOME/cron_logs/backup.log"

# Create backup directory if it doesn't exist
mkdir -p $BACKUP_DIR

# Backup important files
tar -czf "$BACKUP_DIR/home_backup_$DATE.tar.gz" -C $HOME \
    --exclude='backups' \
    --exclude='cron_logs' \
    . 2>/dev/null

if [ $? -eq 0 ]; then
    echo "$(date): Backup completed successfully - home_backup_$DATE.tar.gz" >> $LOG_FILE
else
    echo "$(date): Backup failed" >> $LOG_FILE
fi

# Keep only the last 5 backups
cd $BACKUP_DIR
ls -t home_backup_*.tar.gz | tail -n +6 | xargs -r rm
EOF

# Create a cleanup script
cat > ~/cron_scripts/cleanup_script.sh << 'EOF'
#!/bin/bash
# Cleanup old log files
LOG_FILE="$HOME/cron_logs/cleanup.log"
DATE=$(date '+%Y-%m-%d %H:%M:%S')

echo "$DATE: Starting cleanup process" >> $LOG_FILE

# Clean up old log files (older than 7 days)
find $HOME/cron_logs -name "*.log" -type f -mtime +7 -delete 2>/dev/null

# Clean up temporary files
find /tmp -name "tmp*" -user $USER -mtime +1 -delete 2>/dev/null

echo "$DATE: Cleanup process completed" >> $LOG_FILE
EOF

# Make all scripts executable
chmod +x ~/cron_scripts/*.sh
