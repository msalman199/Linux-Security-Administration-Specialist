Subtask 1.4: Introduction to nftables
Install and configure nftables as a modern replacement for iptables:

# Install nftables
sudo apt install -y nftables

# Create nftables configuration
sudo nano /etc/nftables-security.conf
Add the following nftables configuration:

#!/usr/sbin/nft -f

# Clear existing rules
flush ruleset

# Define variables
define SSH_PORT = 22
define HTTP_PORT = 80
define HTTPS_PORT = 443

table inet security_table {
    chain input {
        type filter hook input priority 0; policy drop;
        
        # Allow loopback
        iif lo accept
        
        # Allow established and related connections
        ct state established,related accept
        
        # Allow SSH with rate limiting
        tcp dport $SSH_PORT ct state new limit rate 4/minute accept
        
        # Allow HTTP and HTTPS
        tcp dport { $HTTP_PORT, $HTTPS_PORT } accept
        
        # Allow ping
        icmp type echo-request limit rate 1/second accept
        
        # Log and drop everything else
        log prefix "nftables-dropped: " drop
    }
    
    chain forward {
        type filter hook forward priority 0; policy drop;
    }
    
    chain output {
        type filter hook output priority 0; policy accept;
    }
}
Apply the nftables configuration:

# Load the configuration
sudo nft -f /etc/nftables-security.conf

# View current rules
sudo nft list ruleset

# Enable nftables service
sudo systemctl enable nftables
sudo systemctl start nftables
Task 2: Advanced Security with SELinux and AppArmor
Subtask 2.1: Working with SELinux
Check if SELinux is available and configure it:

# Check SELinux status
sestatus

# If SELinux is not installed, install it (Ubuntu/Debian)
sudo apt install -y selinux-utils selinux-basics

# Check current SELinux mode
getenforce

# View SELinux contexts
ls -Z /etc/passwd
ps -eZ | head -10
Create a custom SELinux policy:

# Install policy development tools
sudo apt install -y policycoreutils-dev

# Create a directory for our custom policy
mkdir ~/selinux-policy
cd ~/selinux-policy

# Create a simple policy file
nano myapp.te
Add the following SELinux policy content:

policy_module(myapp, 1.0)

# Define the domain for our application
type myapp_t;
type myapp_exec_t;
domain_type(myapp_t)
domain_entry_file(myapp_t, myapp_exec_t)

# Allow the application to execute
allow myapp_t myapp_exec_t:file { read execute };

# Allow basic operations
allow myapp_t self:process { fork signal };
allow myapp_t self:fifo_file rw_fifo_file_perms;

# Allow network access
allow myapp_t self:tcp_socket create_stream_socket_perms;
allow myapp_t self:udp_socket create_socket_perms;
Compile and install the policy:

# Compile the policy
make -f /usr/share/selinux/devel/Makefile myapp.pp

# Install the policy module
sudo semodule -i myapp.pp

# List installed modules
semodule -l | grep myapp
Subtask 2.2: Configuring AppArmor
AppArmor is more commonly available on Ubuntu systems:

# Check AppArmor status
sudo apparmor_status

# Install AppArmor utilities if needed
sudo apt install -y apparmor-utils

# View current profiles
sudo aa-status

# List available profiles
ls /etc/apparmor.d/
Create a custom AppArmor profile:

# Create a simple test application
sudo nano /usr/local/bin/testapp
Add the following content:

#!/bin/bash
echo "Test application running"
echo "Current user: $(whoami)"
echo "Current directory: $(pwd)"
ls /etc/ | head -5
Make it executable:

sudo chmod +x /usr/local/bin/testapp
Create an AppArmor profile for the test application:

# Generate a basic profile
sudo aa-genprof /usr/local/bin/testapp
Follow the interactive prompts, then create a custom profile:

sudo nano /etc/apparmor.d/usr.local.bin.testapp
Add the following AppArmor profile:

#include <tunables/global>

/usr/local/bin/testapp {
  #include <abstractions/base>
  #include <abstractions/bash>

  # Allow execution of the script
  /usr/local/bin/testapp r,
  /bin/bash ix,
  /bin/dash ix,

  # Allow reading system information
  /etc/ r,
  /etc/** r,
  /proc/version r,
  /usr/bin/whoami ix,
  /usr/bin/ls ix,
  /bin/pwd ix,
  /usr/bin/head ix,

  # Deny write access to sensitive areas
  deny /etc/passwd w,
  deny /etc/shadow rw,
  deny /root/** rw,
}
Load and enforce the profile:

# Parse and load the profile
sudo apparmor_parser -r /etc/apparmor.d/usr.local.bin.testapp

# Check profile status
sudo aa-status | grep testapp

# Test the application
/usr/local/bin/testapp
Subtask 2.3: Managing Security Contexts
Create scripts to manage security contexts:

# Create security context management script
sudo nano /usr/local/bin/security-context-manager.sh
Add the following content:

#!/bin/bash

echo "=== Security Context Manager ==="
echo

# Function to check SELinux contexts
check_selinux() {
    echo "SELinux Status:"
    if command -v sestatus >/dev/null 2>&1; then
        sestatus
        echo
        echo "File contexts in /var/log:"
        ls -Z /var/log/ | head -5
    else
        echo "SELinux not available"
    fi
    echo
}

# Function to check AppArmor status
check_apparmor() {
    echo "AppArmor Status:"
    if command -v aa-status >/dev/null 2>&1; then
        sudo aa-status | head -10
    else
        echo "AppArmor not available"
    fi
    echo
}

# Function to show process security contexts
show_process_contexts() {
    echo "Process Security Contexts:"
    ps -eZ | head -10
    echo
}

# Main execution
check_selinux
check_apparmor
show_process_contexts

echo "Security context check completed"
Make it executable and run:

sudo chmod +x /usr/local/bin/security-context-manager.sh
sudo /usr/local/bin/security-context-manager.sh
Task 3: Vulnerability Assessment
Subtask 3.1: System Information Gathering
Create a comprehensive system assessment script:

# Create vulnerability assessment script
nano ~/vulnerability-assessment.sh
Add the following content:

#!/bin/bash

REPORT_FILE="vulnerability_report_$(date +%Y%m%d_%H%M%S).txt"

echo "=== Linux Security Vulnerability Assessment ===" > $REPORT_FILE
echo "Assessment Date: $(date)" >> $REPORT_FILE
echo "System: $(uname -a)" >> $REPORT_FILE
echo >> $REPORT_FILE

# System Information
echo "=== SYSTEM INFORMATION ===" >> $REPORT_FILE
echo "Hostname: $(hostname)" >> $REPORT_FILE
echo "Uptime: $(uptime)" >> $REPORT_FILE
echo "Kernel Version: $(uname -r)" >> $REPORT_FILE
echo "Distribution: $(lsb_release -d 2>/dev/null || cat /etc/os-release | grep PRETTY_NAME)" >> $REPORT_FILE
echo >> $REPORT_FILE

# Network Configuration
echo "=== NETWORK CONFIGURATION ===" >> $REPORT_FILE
echo "Network Interfaces:" >> $REPORT_FILE
ip addr show >> $REPORT_FILE
echo >> $REPORT_FILE

echo "Listening Ports:" >> $REPORT_FILE
ss -tuln >> $REPORT_FILE
echo >> $REPORT_FILE

# User Accounts
echo "=== USER ACCOUNTS ===" >> $REPORT_FILE
echo "User accounts with login shells:" >> $REPORT_FILE
grep -E "(/bin/bash|/bin/sh|/bin/zsh)" /etc/passwd >> $REPORT_FILE
echo >> $REPORT_FILE

echo "Users with UID 0 (root privileges):" >> $REPORT_FILE
awk -F: '$3 == 0 {print $1}' /etc/passwd >> $REPORT_FILE
echo >> $REPORT_FILE

# File Permissions
echo "=== CRITICAL FILE PERMISSIONS ===" >> $REPORT_FILE
echo "World-writable files in /etc:" >> $REPORT_FILE
find /etc -type f -perm -002 2>/dev/null >> $REPORT_FILE
echo >> $REPORT_FILE

echo "SUID files:" >> $REPORT_FILE
find / -type f -perm -4000 2>/dev/null | head -20 >> $REPORT_FILE
echo >> $REPORT_FILE

# Services
echo "=== RUNNING SERVICES ===" >> $REPORT_FILE
systemctl list-units --type=service --state=running >> $REPORT_FILE
echo >> $REPORT_FILE

# Security Tools Status
echo "=== SECURITY TOOLS STATUS ===" >> $REPORT_FILE
echo "Firewall Status:" >> $REPORT_FILE
if command -v ufw >/dev/null 2>&1; then
    sudo ufw status >> $REPORT_FILE
elif command -v iptables >/dev/null 2>&1; then
    sudo iptables -L >> $REPORT_FILE
fi
echo >> $REPORT_FILE

echo "Assessment completed. Report saved to: $REPORT_FILE"
Make it executable and run:

chmod +x ~/vulnerability-assessment.sh
./vulnerability-assessment.sh
Subtask 3.2: Network Security Scanning
Install and use network security tools:

# Install network scanning tools
sudo apt update
sudo apt install -y nmap netcat-openbsd

# Create network security scan script
nano ~/network-security-scan.sh
Add the following content:

#!/bin/bash

SCAN_REPORT="network_scan_$(date +%Y%m%d_%H%M%S).txt"

echo "=== Network Security Scan Report ===" > $SCAN_REPORT
echo "Scan Date: $(date)" >> $SCAN_REPORT
echo >> $SCAN_REPORT

# Get local IP address
LOCAL_IP=$(ip route get 8.8.8.8 | awk '{print $7; exit}')
echo "Local IP Address: $LOCAL_IP" >> $SCAN_REPORT
echo >> $SCAN_REPORT

# Port scan of localhost
echo "=== LOCALHOST PORT SCAN ===" >> $SCAN_REPORT
nmap -sS -O localhost >> $SCAN_REPORT 2>&1
echo >> $SCAN_REPORT

# Service detection
echo "=== SERVICE DETECTION ===" >> $SCAN_REPORT
nmap -sV localhost >> $SCAN_REPORT 2>&1
echo >> $SCAN_REPORT

# Check for common vulnerabilities
echo "=== VULNERABILITY SCAN ===" >> $SCAN_REPORT
nmap --script vuln localhost >> $SCAN_REPORT 2>&1
echo >> $SCAN_REPORT

# Test common ports
echo "=== COMMON PORT CONNECTIVITY ===" >> $SCAN_REPORT
for port in 21 22 23 25 53 80 110 143 443 993 995; do
    if nc -z localhost $port 2>/dev/null; then
        echo "Port $port: OPEN" >> $SCAN_REPORT
    else
        echo "Port $port: CLOSED" >> $SCAN_REPORT
    fi
done

echo >> $SCAN_REPORT
echo "Network scan completed. Report saved to: $SCAN_REPORT"
Run the network security scan:

chmod +x ~/network-security-scan.sh
./network-security-scan.sh
